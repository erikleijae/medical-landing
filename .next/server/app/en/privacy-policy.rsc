[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","en","children","privacy-policy","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]]}],{"children":["__PAGE__",["$","$4","c",{"children":[["$","main",null,{"className":"min-h-screen bg-white text-slate-900","children":["$","div",null,{"className":"mx-auto max-w-3xl px-6 py-16","children":[["$","p",null,{"className":"text-xs font-semibold uppercase tracking-[0.2em] text-slate-400","children":"Legal"}],["$","h1",null,{"className":"mt-3 text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl","children":"Privacy policy"}],["$","p",null,{"className":"mt-1 text-sm text-slate-500","children":"Copiloto Médico"}],["$","section",null,{"className":"mt-6 space-y-3 text-sm leading-relaxed text-slate-700","children":[["$","h2",null,{"className":"text-base font-semibold text-slate-900","children":"1. Purpose of this website privacy policy"}],["$","p",null,{"children":"At Copiloto Médico (\"Copiloto Médico\" or \"we\"), we prioritise your privacy and are committed to safeguarding your personal data. This Privacy Policy explains how we collect, use, protect, and manage your personal data when you visit our website or otherwise interact with us as a user or prospective client. It also sets out your privacy rights and how the law protects you."}],["$","p",null,{"children":"This Website Privacy Policy describes how we handle your personal data when you visit our website (the \"Website\"). Together with our terms of use, it governs your use of the Website and sets out the basis on which any personal data collected from you, or provided by you, will be processed."}],["$","p",null,{"children":"For ease of navigation, this Privacy Policy is presented in sections. Please read this document carefully so that you understand our practices regarding your personal data and how we will handle it."}]]}],["$","section",null,{"className":"mt-8 space-y-3 text-sm leading-relaxed text-slate-700","children":[["$","h2",null,{"className":"text-base font-semibold text-slate-900","children":"2. Data controller"}],["$","p",null,{"children":"For the purposes described in this Privacy Policy, Copiloto Médico acts as the data controller. This means that we determine the purposes and means of the processing of your personal data when you use the Website or otherwise interact with us in the context of this policy."}],["$","p",null,{"children":"We have appointed a person responsible for privacy matters (Data Protection Officer or equivalent). If you have any questions about how we process your personal data or if you wish to exercise your rights, you can contact us using the contact details provided on this website (for example, through the contact form or the email address indicated in the footer)."}],["$","p",null,{"children":"Our Privacy Policy is reviewed regularly and may be updated from time to time. When we make important changes, we will publish the updated version on this page and, where appropriate, notify you for example by email or the next time you access the Website. Please review this page regularly to stay informed about how we process your personal data."}]]}],["$","section",null,{"className":"mt-8 space-y-3 text-sm leading-relaxed text-slate-700","children":[["$","h2",null,{"className":"text-base font-semibold text-slate-900","children":"3. Third party links"}],["$","p",null,{"children":"From time to time, the Copiloto Médico Website may include links to websites belonging to partner networks and other third parties. These websites and any services they provide operate under their own privacy policies. We are not responsible for the privacy practices of those websites or services. We encourage you to read their privacy policies before submitting any personal data or using their services."}]]}],["$","section",null,{"className":"mt-8 space-y-3 text-sm leading-relaxed text-slate-700","children":[["$","h2",null,{"className":"text-base font-semibold text-slate-900","children":"4. What personal data we collect about you"}],["$","p",null,{"children":"Depending on how you interact with the Website, we may collect, use, store and transfer different kinds of personal data about you, including:"}],["$","ul",null,{"className":"list-disc space-y-1 pl-5","children":[["$","li",null,{"children":[["$","span",null,{"className":"font-semibold","children":"Identity information:"}]," for example your first and last name, username or similar identifier, provided when you show interest in our application or apply for a role."]}],["$","li",null,{"children":[["$","span",null,{"className":"font-semibold","children":"Contact information:"}]," such as your email address and details of your organisation when you ask to be contacted or apply for a job through the Website."]}],["$","li",null,{"children":[["$","span",null,{"className":"font-semibold","children":"Technical information:"}]," including information about your use of the Website, such as traffic data, communication data and the resources that you access. This helps us improve the performance and security of the Website."]}],["$","li",null,{"children":[["$","span",null,{"className":"font-semibold","children":"Qualification and professional data:"}]," for example your qualifications, professional registrations, employment history and any cover letter or personal statement you submit."]}]]}],["$","p",null,{"children":"We may also create and use aggregated data (for example, statistical or demographic information). Aggregated data may be derived from your personal data but is not considered personal data in law as it does not directly or indirectly reveal your identity. If we combine or connect aggregated data with your personal data so that it can identify you, we treat the combined data as personal data and handle it in line with this Privacy Policy."}]]}],["$","section",null,{"className":"mt-8 space-y-3 text-sm leading-relaxed text-slate-700","children":[["$","h2",null,{"className":"text-base font-semibold text-slate-900","children":"5. How is your personal data collected?"}],["$","p",null,{"children":"Most of the personal data we process comes directly from you, for example when you fill in a contact form, subscribe to updates or apply for a position via the Website. In addition, we automatically collect certain technical data about your equipment, browsing actions and patterns by using cookies and similar technologies. For more information, please refer to our cookie policy."}]]}],["$","section",null,{"className":"mt-8 space-y-3 text-sm leading-relaxed text-slate-700","children":[["$","h2",null,{"className":"text-base font-semibold text-slate-900","children":"6. How we use your personal data"}],["$","p",null,{"children":"We will only use your personal data when the law allows us to. Most commonly, we will use your personal data in the following circumstances:"}],["$","ul",null,{"className":"list-disc space-y-1 pl-5","children":[["$","li",null,{"children":[["$","span",null,{"className":"font-semibold","children":"With your consent:"}]," where you have clearly agreed that we may process your personal data for a specific purpose. You may withdraw your consent at any time."]}],["$","li",null,{"children":[["$","span",null,{"className":"font-semibold","children":"Legitimate interests:"}]," where processing is necessary for our legitimate interests (or those of a third party) and your interests and fundamental rights do not override those interests, for example to run our business, manage the Website and communicate with users and candidates."]}],["$","li",null,{"children":[["$","span",null,{"className":"font-semibold","children":"Legal or regulatory obligations:"}]," where we need to comply with a legal or regulatory requirement."]}]]}],["$","p",null,{"children":"Depending on how you interact with us, Copiloto Médico may process your personal data in order to manage your queries, evaluate and manage job applications, administer and protect the Website, ensure compliance with regulatory obligations and improve our services."}]]}],["$","section",null,{"className":"mt-8 space-y-3 text-sm leading-relaxed text-slate-700","children":[["$","h2",null,{"className":"text-base font-semibold text-slate-900","children":"7. Storage of data"}],["$","p",null,{"children":"We keep your personal data only for as long as necessary to fulfil the purposes for which it was collected, including for the purposes of satisfying any legal, accounting or reporting requirements. When the data is no longer needed, we will delete it or anonymise it, unless we are required by law to retain it for a longer period."}],["$","p",null,{"children":"In some circumstances we may anonymise your personal data (so that it can no longer be associated with you) for research or statistical purposes, in which case we may use this information indefinitely without further notice to you."}]]}],["$","section",null,{"className":"mt-8 space-y-3 text-sm leading-relaxed text-slate-700","children":[["$","h2",null,{"className":"text-base font-semibold text-slate-900","children":"8. Disclosures of your personal data"}],["$","p",null,{"children":"Within Copiloto Médico, access to your personal data is limited to those people who need it to perform their duties. We may share your personal data with third-party service providers that act as data processors, such as providers of IT, hosting and support services. These providers are only allowed to process your personal data in accordance with our instructions and must protect it appropriately."}],["$","p",null,{"children":"We may also share your personal data when required to do so by law or when necessary to protect our rights or the rights of others, for example with regulators or public authorities."}]]}],["$","section",null,{"className":"mt-8 space-y-3 text-sm leading-relaxed text-slate-700","children":[["$","h2",null,{"className":"text-base font-semibold text-slate-900","children":"9. Data security"}],["$","p",null,{"children":"We are committed to protecting the confidentiality, integrity and availability of your personal data. We apply appropriate technical and organisational measures to help prevent your personal data from being accidentally lost, used or accessed in an unauthorised way, altered or disclosed."}],["$","p",null,{"children":"Where personal data is transferred outside your country, we take steps to ensure that an adequate level of protection is in place in accordance with applicable data protection laws."}]]}],["$","section",null,{"className":"mt-8 space-y-3 text-sm leading-relaxed text-slate-700","children":[["$","h2",null,{"className":"text-base font-semibold text-slate-900","children":"10. Your rights"}],["$","p",null,{"children":"Depending on where you are located and subject to applicable law, you may have some or all of the following rights in relation to your personal data:"}],["$","ul",null,{"className":"list-disc space-y-1 pl-5","children":[["$","li",null,{"children":"to be informed about how we process your personal data;"}],["$","li",null,{"children":"to access the personal data we hold about you;"}],["$","li",null,{"children":"to request correction of inaccurate or incomplete personal data;"}],["$","li",null,{"children":"to request erasure of your personal data in certain circumstances;"}],["$","li",null,{"children":"to request restriction of processing in certain circumstances;"}],["$","li",null,{"children":"to object to processing based on our legitimate interests;"}],["$","li",null,{"children":"to request the transfer of your personal data to you or to a third party (data portability); and"}],["$","li",null,{"children":"to lodge a complaint with a supervisory authority if you consider that our processing infringes applicable law."}]]}],["$","p",null,{"children":"If you wish to exercise any of these rights, please contact us using the contact details provided on this Website. We may need to request specific information from you to help us confirm your identity and ensure your right to access your personal data (or to exercise any of your other rights)."}]]}],["$","p",null,{"className":"mt-10 text-xs text-slate-500","children":"Last updated: October 5th, 2025"}]]}]}],null,["$","$L8",null,{"children":"$L9"}]]}],{},null]},null]},null]},null],["$","$4","h",{"children":[null,["$","$4","qiozQCttH_1JBfh_pinKy",{"children":[["$","$La",null,{"children":"$Lb"}],["$","$Lc",null,{"children":"$Ld"}],["$","meta",null,{"name":"next-size-adjust"}]]}]]}]]],"m":"$undefined","G":["$e","$undefined"],"s":false,"S":true}
